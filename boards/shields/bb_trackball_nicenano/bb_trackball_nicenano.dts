#include <dt-bindings/zmk/matrix_transform.h>
//#define ZMK_POINTING_DEFAULT_MOVE_VAL 1500  // default: 600
//#define ZMK_POINTING_DEFAULT_SCRL_VAL 20    // default: 10
//#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/pointing.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <1>;
        map = <
        RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)    RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10)
                 RC(0,6)  RC(0,5)  RC(0,4)    RC(0,13) RC(0,12) RC(0,11)
        >;
    };

	kscan0: kscan_0 {
		compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
    };

};

&kscan0 {

    input-gpios
    //Left Finger Row
    = <&gpio1 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

    //Left Thumb Row
    , <&gpio1 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

    //Right Finger Row
    ,<&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio1 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 22 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

    //Right Thumb Row
    , <&gpio1 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio1 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    ;
};




/ {
    bb_trackball: blackberry_trackball {
        compatible = "zmk,bb-gpio-trackball";
        status = "okay";

        up-gpios    = <&gpio0 6  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        down-gpios  = <&gpio0 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        left-gpios  = <&gpio0 17 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        right-gpios = <&gpio0 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        click-gpios = <&gpio1 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

        move-step = <4>;
    };
};