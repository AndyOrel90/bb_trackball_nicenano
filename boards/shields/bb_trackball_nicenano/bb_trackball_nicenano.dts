#include <dt-bindings/zmk/matrix_transform.h>
//#define ZMK_POINTING_DEFAULT_MOVE_VAL 1500  // default: 600
//#define ZMK_POINTING_DEFAULT_SCRL_VAL 20    // default: 10
//#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/input_transform.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {

    /* ---------------------------------------------------------------------- *
     * 1. BlackBerry Trackball — analog-input-driver node                     *
     *                                                                         *
     * The zmk-analog-input-driver treats pairs of "positive" and "negative"  *
     * GPIO channels as a signed axis.  Each hall-sensor pulse is counted as  *
     * +1 or -1 movement.  The driver emits input_event(REL_X) and           *
     * input_event(REL_Y) which ZMK's pointing layer forwards as mouse motion.*
     * ---------------------------------------------------------------------- */

    trackball: trackball {
        compatible = "zmk,analog-input";
        status = "okay";

        /*
         * X-axis: right (+) and left (-)
         * GPIO flags: GPIO_ACTIVE_LOW | GPIO_PULL_UP
         * The hall sensors pull the line low when activated.
         */
        input-gpios
            = <&gpio0 17  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  /* LFT → -X */
            , <&gpio0 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  /* RHT → +X */
            , <&gpio0 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>  /* UP  → -Y */
            , <&gpio0 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>; /* DWN → +Y */

        /*
         * Axis mapping: the driver expects pairs in order
         *   (neg-x, pos-x, neg-y, pos-y)
         * so axes 0-1 map to X and axes 2-3 map to Y.
         */
        input-codes = <INPUT_REL_X INPUT_REL_X INPUT_REL_Y INPUT_REL_Y>;

        /*
         * Scale factor: multiply each raw pulse by this integer before
         * emitting the event.  The BB trackball only produces ~9 pulses per
         * full sweep, so multiply by 4–8 to get usable cursor speed.
         * Tune to taste.
         */
        scale-multiplier = <6>;
        scale-divisor    = <1>;

        /*
         * Emit events every time a GPIO edge is detected (no averaging).
         * Fine-grained so the input-processors can further smooth/scale.
         */
        event-type = <INPUT_EV_REL>;
    };
};
/*
/ {
    blackberry_trackball: blackberry_trackball {
        compatible = "zmk,bb-gpio-trackball";
        status = "okay";

        up-gpios    = <&gpio0 6  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        down-gpios  = <&gpio0 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        left-gpios  = <&gpio0 17 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        right-gpios = <&gpio0 20 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        click-gpios = <&gpio1 1 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;

        move-step = <4>;
    };
};
*/

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <1>;
        map = <
        RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)    RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10)
                 RC(0,6)  RC(0,5)  RC(0,4)    RC(0,13) RC(0,12) RC(0,11)
        >;
    };

	kscan0: kscan_0 {
		compatible = "zmk,kscan-gpio-direct";
        wakeup-source;
    };

};

&kscan0 {

    input-gpios
    //Left Finger Row
    = <&gpio1 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio1 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 10 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

    //Left Thumb Row
    , <&gpio1 15 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

    //Right Finger Row
    ,<&gpio0 11 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio1 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 24 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 22 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>

    //Right Thumb Row
    , <&gpio1 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio1 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    , <&gpio0 31 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
    ;
};

